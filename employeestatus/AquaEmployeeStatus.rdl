              </Paragraphs>
              <rd:WatermarkTextbox>Title</rd:WatermarkTextbox>
              <rd:DefaultName>ReportTitle</rd:DefaultName>
              <Top>0.11458in</Top>
              <Height>0.5in</Height>
              <Width>10.38839in</Width>
              <Style>
                <Border>
                  <Style>None</Style>
                </Border>
                <PaddingLeft>2pt</PaddingLeft>
                <PaddingRight>2pt</PaddingRight>
                <PaddingTop>2pt</PaddingTop>
                <PaddingBottom>2pt</PaddingBottom>
              </Style>
            </Textbox>
            <Textbox Name="Textbox15">
              <CanGrow>true</CanGrow>
              <CanShrink>true</CanShrink>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>="&lt;b&gt;Count: &lt;/b&gt;" &amp; "&lt;font color='blue'&gt;" &amp; CountRows("DataSet1") &amp; "&lt;/font&gt;" &amp; "&lt;br&gt;&lt;b&gt;Showing Status: &lt;/b&gt;" &amp; "&lt;font color='blue'&gt;" &amp; IIf(IsNothing(Parameters!Status.Value),"Active &amp; InActive","")  &amp; IIf(Parameters!Status.Value="Active"," Active","") &amp; IIf(Parameters!Status.Value="InActive","InActive","") &amp; "&lt;/font&gt;" &amp; " |  &lt;b&gt;Status Date From: &lt;/b&gt;" &amp;  "&lt;font color='blue'&gt;" &amp; IIf(IsNothing(Parameters!FromDate.Value)," Showing All Dates",Parameters!FromDate.Value) &amp; "&lt;/font&gt;" &amp; " | &lt;b&gt;Status Date To: &lt;/b&gt;" &amp;  "&lt;font color='blue'&gt;" &amp; IIf(IsNothing(Parameters!ToDate.Value)," Showing All Dates",Parameters!ToDate.Value) &amp; "&lt;/font&gt;" &amp; "&lt;br&gt;&lt;b&gt;Department(s): &lt;/b&gt;" &amp;  "&lt;font color='blue'&gt;" &amp; "'" &amp; JOIN(Parameters!Departments.Value,"','") &amp; "'" &amp; "&lt;/font&gt;" &amp; " |  &lt;b&gt;Employee(s): &lt;/b&gt;" &amp;  "&lt;font color='blue'&gt;" &amp; IIf(IsNothing(Parameters!Name.Value)," Showing All Employees",Parameters!Name.Value) &amp; "&lt;/font&gt;"</Value>
