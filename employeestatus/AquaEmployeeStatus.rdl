                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="COMPANYHIREDTM">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIf(Code.IsBlankDate(Fields!COMPANYHIREDTM.Value), "---", Fields!COMPANYHIREDTM.Value)</Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontWeight>Normal</FontWeight>
                                    <Format>M/d/yy</Format>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#333333</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>COMPANYHIREDTM</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="YearsOfService">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIf(Code.IsBlankDate(Fields!COMPANYHIREDTM.Value), "---", IIf(Fields!USERACCOUNTSTATUS.Value="Inactive" AndAlso Code.DatesEqual(Fields!COMPANYHIREDTM.Value, Fields!HireDate.Value), "---", IIf(IsNothing(Fields!COMPANYHIREDTM.Value), "---", IIf((Fields!YearsOfService.Value=0 AND (Fields!DaysOfService.Value&lt;31 AND Fields!YearsOfService.Value=-1) Or (Fields!DaysOfService.Value&lt;31)) AND Fields!USERACCOUNTSTATUS.Value="Inactive", IIf(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) &gt;= 365, CInt(Math.Floor(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) / 365)) &amp; IIf(CInt(Math.Floor(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) / 365)) = 1, " yr.", " yrs."), IIf(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) &gt;= 31, CInt(Math.Floor(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) / 30.44)) &amp; IIf(CInt(Math.Floor(ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) / 30.44)) = 1, " mo.", " mos."), ABS(DATEDIFF(DateInterval.Day, Fields!HireDate.Value, Fields!COMPANYHIREDTM.Value)) &amp; " day(s)")),IIf((Fields!YearsOfService.Value=0 AND (Fields!DaysOfService.Value&lt;31 AND Fields!YearsOfService.Value=-1) Or (Fields!DaysOfService.Value&lt;31)) AND Fields!USERACCOUNTSTATUS.Value="Active", ABS(DATEDIFF(DateInterval.Day, Today, Fields!COMPANYHIREDTM.Value)) &amp; " day(s)",IIf(Fields!YearsOfService.Value = -2 Or Fields!YearsOfService.Value = -3 Or Fields!YearsOfService.Value = -4 
Or Fields!YearsOfService.Value = -5 Or Fields!YearsOfService.Value = -6 Or Fields!YearsOfService.Value = -7 Or Fields!YearsOfService.Value = -8 or Fields!YearsOfService.Value = -9 Or Fields!YearsOfService.Value = -10 Or Fields!YearsOfService.Value = -11, Abs(Fields!YearsOfService.Value) &amp; " mos.",IIf(Fields!YearsOfService.Value=1, Fields!YearsOfService.Value &amp; " yr.",IIf(Fields!YearsOfService.Value&gt;1, Fields!YearsOfService.Value &amp; " yrs.",Abs(Fields!YearsOfService.Value) &amp; " mo."))))))))</Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#333333</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>YearsOfService</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HireDate">
