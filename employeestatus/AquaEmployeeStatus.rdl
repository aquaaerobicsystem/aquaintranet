  <Code>Public Function fixString (ByVal s As String) As String

Dim  mystring() As String  

mystring = s.Split(",")

For index As Integer = 0 To mystring.Length-1
    mystring(index) = Trim(mystring(index))
Next 

Return Join(mystring, ",")

End Function

Public Function IsBlankDate(ByVal v As Object) As Boolean
  If v Is Nothing Then Return True
  If Convert.IsDBNull(v) Then Return True
  If Trim(v.ToString()) = "" Then Return True
  Return False
End Function

Public Function DatesEqual(ByVal a As Object, ByVal b As Object) As Boolean
  If IsBlankDate(a) OrElse IsBlankDate(b) Then Return False
  Try
    Return CDate(a).Date = CDate(b).Date
  Catch
    Return False
  End Try
End Function</Code>
