                              <TextRuns>
                                <TextRun>
                                  <Value>=IIf(Code.IsBlankDate(Fields!COMPANYHIREDTM.Value), "---", IIf(Fields!USERACCOUNTSTATUS.Value="Active", "   ---", IIf(Code.DatesEqual(Fields!COMPANYHIREDTM.Value, Fields!HireDate.Value), "---", Fields!HireDate.Value)))</Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontWeight>Normal</FontWeight>
