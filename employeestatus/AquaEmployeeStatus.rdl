  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>/Epicor10Live/reports/aquaerpdb_Custom</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>397e7ce3-53a6-4bb6-852d-9547de719a4a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Departments">
            <Value>=Parameters!Departments.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Name">
            <Value>=Parameters!Name.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select * From (
  SELECT
    LTRIM(RTRIM(CAST(ax.[EmpNum] AS VARCHAR(20)))) AS EmpID,
    CASE
      WHEN ax.[Active] = '1' AND ABS(DATEDIFF(month, GETDATE(), ax.[HireDate])) &lt; 12
        THEN DATEDIFF(month, GETDATE(), ax.[HireDate])
      WHEN ax.[Active] = '1' AND ABS(DATEDIFF(month, GETDATE(), ax.[HireDate])) &gt; 11
        THEN ABS(DATEDIFF(month, GETDATE(), ax.[HireDate])/12)
      WHEN ax.[Active] = '0' AND ABS(DATEDIFF(month, ax.[TerminationDate], ax.[HireDate])) &lt; 12
        THEN DATEDIFF(month, ax.[TerminationDate], ax.[HireDate])
      WHEN ax.[Active] = '0' AND ABS(DATEDIFF(month, ax.[TerminationDate], ax.[HireDate])) &gt; 11
        THEN ABS(DATEDIFF(month, ax.[TerminationDate], ax.[HireDate])/12)
      ELSE 0
    END AS YearsOfService,
    CASE
      WHEN ax.[Active] = '1' AND ax.[HireDate] IS NOT NULL
        THEN ABS(DATEDIFF(day, GETDATE(), ax.[HireDate]))
      WHEN ax.[Active] = '0' AND ax.[HireDate] IS NOT NULL
        THEN ABS(DATEDIFF(day, ax.[TerminationDate], ax.[HireDate]))
      ELSE 0
    END AS DaysOfService,
    ax.[HireDate] AS COMPANYHIREDTM,
    ax.[FirstName] AS FIRSTNM,
    ax.[LastName] AS LASTNM,
    ax.[DeptDesc] AS Dir,
    CASE WHEN ax.[Active] = '1' THEN ax.[HireDate]
         ELSE ISNULL(ax.[TerminationDate], ax.[HireDate]) END AS HireDate,
    ax.[DeptDesc] AS Department,
    CASE WHEN ax.[Active] = '0' THEN 'Inactive' ELSE 'Active' END AS [USERACCOUNTSTATUS],
    ROW_NUMBER() OVER (
      PARTITION BY
        ax.[Active],
        UPPER(LTRIM(RTRIM(ISNULL(ax.[LastName], '')))),
        UPPER(LEFT(LTRIM(RTRIM(ISNULL(ax.[FirstName], ''))),
              CHARINDEX(' ', LTRIM(RTRIM(ISNULL(ax.[FirstName], ''))) + ' ') - 1))
      ORDER BY
        CASE
          WHEN ax.[HireDate] IS NULL THEN 1
          WHEN ax.[Active] = '0' AND ISNULL(ax.[TerminationDate], ax.[HireDate]) = ax.[HireDate] THEN 1
          ELSE 0
        END ASC,
        CASE WHEN ax.[Active] = '0' THEN ax.[TerminationDate] END DESC,
        ax.[HireDate] DESC
    ) AS rn,
    ax.[DeptDesc] AS [HOMELABORLEVELDSC1]
  FROM AquaErpdb.[Custom].[dbo].[AcctSys_ActiveInActiveEmps_Report] AS ax
  WHERE ax.[FirstName] IS NOT NULL
    AND ax.[FirstName] &lt;&gt; 'Labor'
    AND ISNULL(ax.[LastName], '') NOT LIKE '%test%'
) as S
WHERE S.[rn] = 1
  AND (@Status = 'ALL' Or S.[USERACCOUNTSTATUS] = @Status)
  AND ((@FromDate is NULL Or S.[HireDate] &gt;= @FromDate) AND (@ToDate is NULL Or S.[HireDate] &lt;= @ToDate))
  AND (@Name = ' ALL' Or S.[LASTNM] + ', ' + S.[FIRSTNM] = @Name)
ORDER BY 
  S.[USERACCOUNTSTATUS],
  CASE WHEN S.[USERACCOUNTSTATUS] = 'Active'  THEN S.[HireDate] END DESC,
  CASE WHEN S.[USERACCOUNTSTATUS] = 'Inactive' THEN S.[HireDate] END DESC,
  S.[LASTNM]</CommandText>
      </Query>
      <Fields>
        <Field Name="YearsServiceReport">
          <Value>=IIf((Fields!YearsOfService.Value=0 AND (Fields!DaysOfService.Value&lt;31 AND Fields!YearsOfService.Value=-1) Or (Fields!DaysOfService.Value&lt;31)) AND Fields!USERACCOUNTSTATUS.Value="Inactive", 0,IIf((Fields!YearsOfService.Value=0 AND (Fields!DaysOfService.Value&lt;31 AND Fields!YearsOfService.Value=-1) Or (Fields!DaysOfService.Value&lt;31)) AND Fields!USERACCOUNTSTATUS.Value="Active", 0,IIf(Fields!YearsOfService.Value = -2 Or Fields!YearsOfService.Value = -3 Or Fields!YearsOfService.Value = -4 
Or Fields!YearsOfService.Value = -5 Or Fields!YearsOfService.Value = -6 Or Fields!YearsOfService.Value = -7 Or Fields!YearsOfService.Value = -8 or Fields!YearsOfService.Value = -9 Or Fields!YearsOfService.Value = -10 Or Fields!YearsOfService.Value = -11, 0,IIf(Fields!YearsOfService.Value=1, Fields!YearsOfService.Value,IIf(Fields!YearsOfService.Value&gt;1, Fields!YearsOfService.Value,0)))))</Value>
        </Field>
        <Field Name="EmpID">
          <DataField>EmpID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="YearsOfService">
          <DataField>YearsOfService</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DaysOfService">
          <DataField>DaysOfService</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="COMPANYHIREDTM">
          <DataField>COMPANYHIREDTM</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="FIRSTNM">
          <DataField>FIRSTNM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LASTNM">
          <DataField>LASTNM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Dir">
          <DataField>Dir</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="HireDate">
          <DataField>HireDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Department">
          <DataField>Department</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="USERACCOUNTSTATUS">
          <DataField>USERACCOUNTSTATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="rn">
          <DataField>rn</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="HOMELABORLEVELDSC1">
          <DataField>HOMELABORLEVELDSC1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Dir.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!Departments.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="Departments">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT [DeptDesc] As Department
FROM AquaErpdb.[Custom].[dbo].[AcctSys_ActiveInActiveEmps_Report]
WHERE [DeptDesc] IS NOT NULL
ORDER BY Department</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Department">
          <DataField>Department</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Names">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT [LastName] + ', ' + [FirstName] As Name
FROM AquaErpdb.[Custom].[dbo].[AcctSys_ActiveInActiveEmps_Report]
WHERE [FirstName] Is Not Null AND ISNULL([LastName], '') Not Like '%test%'
UNION
SELECT ' ALL'
ORDER BY Name</CommandText>
      </Query>
      <Fields>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
